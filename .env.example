# ===========================================
# InsertQ 应用配置文件示例
# 复制此文件为 .env 并修改配置值
# ===========================================

# ----------------- 数据库配置 -----------------
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_database_password
MYSQL_DB=insertq_db

# ----------------- 应用密钥 -----------------
# 必须设置！生成随机密钥: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ----------------- SMTP邮件配置 -----------------
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_DEFAULT_SENDER=your_email@example.com

# ----------------- Redis配置 -----------------
REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1
SESSION_REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ----------------- 文件上传配置 -----------------
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=xlsx,xls,csv,txt,jpg,jpeg,png,gif

# ----------------- 分页配置 -----------------
RECORDS_PER_PAGE=20
SEARCH_RESULTS_PER_PAGE=12

# ----------------- Session配置 -----------------
SESSION_LIFETIME_DAYS=7
SESSION_COOKIE_SECURE=false

# ----------------- 应用环境 -----------------
FLASK_ENV=development
FLASK_DEBUG=true

# ----------------- 模板自动重载 -----------------
# 生产环境改为 true 可即时看到模板修改，改完建议改回 false
TEMPLATES_AUTO_RELOAD=false

# ----------------- Sentry错误追踪 -----------------
# 注册 https://sentry.io 获取 DSN，留空则禁用
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
