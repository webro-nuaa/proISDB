# ===========================================
# InsertQ 应用配置文件
# 复制此文件为 .env 并修改配置值
# cp .env.example .env
# ===========================================

# ==========================================
# ⚠️ 必须修改（Docker 部署前必须设置）
# ==========================================

# 数据库密码（MySQL root 密码，自己定一个强密码）
MYSQL_PASSWORD=change_me_to_a_strong_password

# 应用密钥（用于加密 Session 和 CSRF Token）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_string

# ==========================================
# 可选修改（一般不用改）
# ==========================================

# 数据库配置
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_DB=insertq_db

# 应用环境（生产环境改为 production）
FLASK_ENV=production
FLASK_DEBUG=false

# ==========================================
# Docker 部署时自动覆盖（不需要改）
# ==========================================
# 以下配置在 docker-compose.yml 中已通过 environment 覆盖
# Docker 部署时这些值会被自动设为容器内网地址
# 只有不用 Docker 部署时才需要修改

REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_URL=redis://localhost:6379/1
SESSION_REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==========================================
# 可选功能（按需开启）
# ==========================================

# SMTP 邮件配置（不配则邮件功能不可用）
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# Sentry 错误追踪（留空禁用，注册 https://sentry.io 获取 DSN）
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# 模板自动重载（生产环境建议 false）
TEMPLATES_AUTO_RELOAD=false

# 文件上传
MAX_CONTENT_LENGTH_MB=16
ALLOWED_EXTENSIONS=xlsx,xls,csv,txt,jpg,jpeg,png,gif

# 分页
RECORDS_PER_PAGE=20
SEARCH_RESULTS_PER_PAGE=12

# Session
SESSION_LIFETIME_DAYS=7
SESSION_COOKIE_SECURE=false
